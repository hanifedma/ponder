rules_version = '2';

// Each user's data lives under /users/{uid}/... (e.g. /quotes, /healthtips).
// A signed-in user can ONLY read and write documents under their own uid.
// Nobody can read or write anyone else's data.
service cloud.firestore {
  match /databases/{database}/documents {

    // Any subcollection (quotes, healthtips, …) under the user's own path.
    match /users/{userId}/{collection}/{docId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
